# Server Configuration
PORT=4000
NODE_ENV=development

# Database Configuration
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=
REDIS_USERNAME=

PGADMIN_DEFAULT_EMAIL=admin@local.com
PGADMIN_DEFAULT_PASSWORD=admin123

JWT_SECRET=
JWT_EXPIRER_AT="1d"

PRIVATE_KEY=
PRIVATE_KEY_2=

# Soroban (Stellar) Configuration
# The backend never holds artist secret keys — artists sign Soroban
# invocations client-side (e.g. Freighter) and the backend only builds and
# relays transactions. These are the deployed AudioBlocks Soroban contract
# IDs and RPC endpoint (see AudioB_Contract_Soroban/README.md).
SOROBAN_NETWORK=testnet
SOROBAN_TESTNET_RPC_URL=https://soroban-testnet.stellar.org
SOROBAN_TESTNET_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
SOROBAN_TESTNET_NFT_CONTRACT_ID=
SOROBAN_TESTNET_ARTIST_CONTRACT_ID=
SOROBAN_TESTNET_CATALOG_CONTRACT_ID=
SOROBAN_TESTNET_ROYALTY_CONTRACT_ID=
SOROBAN_TESTNET_MARKETPLACE_CONTRACT_ID=
SOROBAN_MAINNET_RPC_URL=https://mainnet.sorobanrpc.com
SOROBAN_MAINNET_NETWORK_PASSPHRASE="Public Global Stellar Network ; September 2015"
SOROBAN_MAINNET_NFT_CONTRACT_ID=
SOROBAN_MAINNET_ARTIST_CONTRACT_ID=
SOROBAN_MAINNET_CATALOG_CONTRACT_ID=
SOROBAN_MAINNET_ROYALTY_CONTRACT_ID=
SOROBAN_MAINNET_MARKETPLACE_CONTRACT_ID=

# Comma-separated list of allowed CORS origins (listener-app and artist-dashboard deployed domains).
# Example: https://listener.audioblockz.com,https://artist.audioblockz.com
# Defaults to localhost origins when unset.
ALLOWED_ORIGINS=

# Twitter OAuth 2.0 (PKCE) — used for artist Twitter account linking
# Register your app at https://developer.twitter.com/en/apps and enable OAuth 2.0.
TWITTER_APP_ID=
TWITTER_API_KEY=
TWITTER_API_SECRET_KEY=
TWITTER_AUTH_TOKEN=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# OAuth 2.0 PKCE credentials (set in the Twitter developer portal)
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
# The callback URL registered in the Twitter app (must match exactly)
TWITTER_REDIRECT_URI=http://localhost:4000/api/auth/twitter/callback

# Artist-dashboard route that receives the post-OAuth redirect.
# The frontend reads the ?twitter_connected=1 query param and updates its UI.
# REQUIRED — startup will throw if unset.
# Example: https://artist.audioblockz.com/settings/social
TWITTER_SUCCESS_REDIRECT=

# Email Configuration
EMAIL_PROVIDER=resend
EMAIL_API_KEY=
EMAIL_FROM=noreply@audioblocks.com

# Frontend URL for email verification and password reset links
APP_URL=http://localhost:3000
