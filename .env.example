# Server Configuration
PORT=4000
NODE_ENV=development

# Database Configuration
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=
REDIS_USERNAME=

PGADMIN_DEFAULT_EMAIL=admin@local.com
PGADMIN_DEFAULT_PASSWORD=admin123

JWT_SECRET=
JWT_EXPIRER_AT="1d"

PRIVATE_KEY=
PRIVATE_KEY_2=

# Soroban (Stellar) Configuration
# The backend never holds artist secret keys — artists sign Soroban
# invocations client-side (e.g. Freighter) and the backend only builds and
# relays transactions. These are the deployed AudioBlocks Soroban contract
# IDs and RPC endpoint (see AudioB_Contract_Soroban/README.md).
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
SOROBAN_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
NFT_CONTRACT_ID=
ARTIST_CONTRACT_ID=
CATALOG_CONTRACT_ID=
ROYALTY_CONTRACT_ID=
MARKETPLACE_CONTRACT_ID=

# Comma-separated list of allowed CORS origins (listener-app and artist-dashboard deployed domains).
# Example: https://listener.audioblockz.com,https://artist.audioblockz.com
# Defaults to localhost origins when unset.
ALLOWED_ORIGINS=

TWITTER_APP_ID=
TWITTER_API_KEY=
TWITTER_API_SECRET_KEY=
TWITTER_AUTH_TOKEN=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
